(* Pattern 4: nested abbreviation hiding function type.
   type fn = nat -> bool
   type wrap = fn            (* abbreviation of abbreviation *)
   type t = T of wrap        (* should NOT derive BEq *)
*)
open import Pervasives

type fn_alias = nat -> bool
type wrap_alias = fn_alias
type nested_alias_variant = NaV of wrap_alias

(* Also test record form *)
type nested_alias_record = <| nar_field : wrap_alias |>
