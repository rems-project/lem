open import Pervasives_extra

(* === Mutually recursive types === *)
type tree 'a =
  | Leaf of 'a
  | Branch of forest 'a
and forest 'a =
  | FNil
  | FCons of tree 'a * forest 'a

(* === Mutually recursive functions === *)
let rec count_tree (t : tree nat) : nat =
  match t with
    | Leaf _ -> 1
    | Branch f -> count_forest f
  end
and count_forest (f : forest nat) : nat =
  match f with
    | FNil -> 0
    | FCons t rest -> count_tree t + count_forest rest
  end

let test1 = count_tree (Leaf 42)
let test2 = count_tree (Branch (FCons (Leaf 1) (FCons (Leaf 2) FNil)))

(* === Mutually recursive even/odd === *)
let rec is_even (n : nat) : bool =
  match n with
    | 0 -> true
    | n -> is_odd (n - 1)
  end
and is_odd (n : nat) : bool =
  match n with
    | 0 -> false
    | n -> is_even (n - 1)
  end

let test3 = is_even 4
let test4 = is_odd 5

(* === Heterogeneous parameter counts (Type 1 universe in Lean) === *)
(* foo has 0 type params, bar has 1 — backend must emit Type 1 for both *)
type foo = A | B of bar nat
and bar 'a = C of 'a | D of foo

let test5 = A
let test6 = B (C 42)
let test7 = D A

(* === 3-way mutual recursion === *)
type m1 = M1A | M1B of m2
and m2 = M2A | M2B of m3
and m3 = M3A | M3B of m1

let test8 = M1A
let test9 = M1B (M2B (M3B M1A))

assert test1_ok : (test1 = (1:nat))
assert test2_ok : (test2 = (2:nat))
assert test3_ok : test3
assert test4_ok : test4
