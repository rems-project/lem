open import Pervasives_extra

type op = 
  | Add | Sub 

type op0 =
  | Not | Neg

type op1 =
  | Unop of op * op0 * op1

let op1 (op : op) : nat = match op with
| Add -> 0
| Sub -> 1
end

let rec Op_fun (op : op) : nat -> nat -> nat = match op with
| Add -> (+)
| Sub -> Op_fun Add
end

let rec op2 (op3 : op) : nat -> nat -> nat = match op3 with
| Add -> (+)
| Sub -> op2 Add
end

let var_scope : nat =
  let op = 0 in
  let op0 = 1 in
  let op1 = 2 in
  op + op0 + op1

let rec var_scope2 (x : nat) : nat =
  if x = 0 then 0 else
  (let op = 0 in
   let op0 = 1 in
   let op1 = 2 in
   op + op0 + op1 + var_scope2 (x - 1))


